# ============================================================================
# Automatic Recon Tool — Environment Configuration
# ============================================================================
# Copy this file to '.env' and fill in your actual credentials.
# The .env file is git-ignored and should NEVER be committed.
# ============================================================================

# ── SMTP Configuration ─────────────────────────────────────────────────────
RECON_SMTP_SERVER=smtp.gmail.com
RECON_SMTP_PORT=587
RECON_SMTP_USER=your_email@gmail.com
RECON_SMTP_PASS=your_app_password_here
RECON_SMTP_USE_TLS=yes

# ── API Keys ───────────────────────────────────────────────────────────────
SHODAN_API_KEY=your_shodan_api_key_here

# ── Directories (optional — defaults are relative to project root) ─────────
# RECON_SCREENSHOTS_DIR=/path/to/screenshots
# RECON_DOCUMENTS_DIR=/path/to/documents
# RECON_LOGS_DIR=/path/to/logs
# RECON_WORDLISTS_DIR=/path/to/wordlists

# ── Timeouts (seconds) ────────────────────────────────────────────────────
# RECON_DNS_TIMEOUT=5
# RECON_HTTP_TIMEOUT=10
# RECON_SSL_TIMEOUT=5
# RECON_SCREENSHOT_TIMEOUT=20
# RECON_SUBDOMAIN_TIMEOUT=300

# ── Concurrency ───────────────────────────────────────────────────────────
# RECON_MAX_WORKERS=8
# RECON_ADMIN_SCAN_WORKERS=10
