# ============================================================================
# Automatic Reconnaissance Tool — .gitignore
# ============================================================================

# ── Sensitive Configuration & Secrets ───────────────────────────────────────
.env
config/smtp_config.txt
smtp_config.txt

# ── Runtime Output & Generated Reports ──────────────────────────────────────
logs/
reports/
output/
screenshots/
*.pdf
*.html
*.json
*.txt
!requirements.txt
!config/wordlists/*.txt

# ── Python Cache & Bytecode ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/

# ── Virtual Environments ────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE & Editor Configuration ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── PyInstaller & Build Artifacts ───────────────────────────────────────────
build/
dist/
*.spec

# ── macOS & OS Specific ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
